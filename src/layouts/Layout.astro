<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Habits - Gamification UI</title>
  <meta name="description" content="Track your habits with gamification and streaks" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

  <script is:inline>
    (function(){try{var t=localStorage.getItem('theme');if(t)document.documentElement.setAttribute('data-theme',t);else{const hour=new Date().getHours();document.documentElement.setAttribute('data-theme',hour>=6&&hour<18?'light':'dark');}}catch(e){document.documentElement.setAttribute('data-theme','dark');}})();
  </script>
</head>
<body>
  <div x-data="app()" x-init="initApp()">
    <slot />
  </div>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      Alpine.data('app', () => ({
        initialized: false,
        async initApp() {
          this.initialized = true
          await this.loadData()
        },
        async loadData() {}
      }))
    })
  </script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</body>
</html>