---
import Layout from '../layouts/Layout.astro'
import '../globals.css'
---

<Layout>
  <div class="container">
    <header class="hero">
      <div class="hero-icon">🎯</div>
      <h1 class="hero-title">Habby</h1>
      <p class="hero-subtitle">Build habits, earn streaks, level up your life.</p>
    </header>

    <section class="card">
      <div class="stat-row">
        <div class="stat-badge streak">
          <span>🔥</span>
          <span>0 days</span>
        </div>
        <div class="stat-badge xp">
          <span>💎</span>
          <span>0 XP</span>
        </div>
      </div>
    </section>

    <section class="card">
      <h2 class="section-heading">Get Started</h2>
      <p class="muted">Track daily habits, watch your streak grow, and unlock achievements as you level up.</p>
    </section>

    <nav class="bottom-nav-spacer" aria-hidden="true"></nav>
  </div>
</Layout>
